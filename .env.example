# ── Telegram Bot ──────────────────────────────────────────────────
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── Database ───────────────────────────────────────────────────────
# Local dev: SQLite (default, no setup needed)
DATABASE_URL=sqlite+aiosqlite:///data/database.db
# Production: paste your Supabase / Render PostgreSQL connection string
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Webhook (production only) ──────────────────────────────────────
# Leave empty for local polling mode.
# Set to your public HTTPS URL on Render/Railway (no trailing slash):
# BOT_WEBHOOK_URL=https://your-app.onrender.com
BOT_WEBHOOK_URL=

# ── AI Photo Analysis (optional) ──────────────────────────────────
# "mock" uses dummy values; "openai" calls GPT-4o Vision
FOOD_AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini
